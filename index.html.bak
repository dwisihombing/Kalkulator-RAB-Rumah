            <div class="field-row"><label>Cat dinding dalam</label><input type="number" id="hs_cdd" value="45000" oninput="calcAll()"><span class="unit">/m²</span></div>
            <div class="field-row"><label>Cat plafon</label><input type="number" id="hs_cpp" value="40000" oninput="calcAll()"><span class="unit">/m²</span></div>
            <div class="field-row"><label>Waterproofing</label><input type="number" id="hs_wf" value="95000" oninput="calcAll()"><span class="unit">/m²</span></div>
            <div class="field-row"><label>Pagar bata + besi</label><input type="number" id="hs_pgr" value="1800000" oninput="calcAll()"><span class="unit">/m</span></div>
            <div class="field-row"><label>Carport beton</label><input type="number" id="hs_cpt" value="350000" oninput="calcAll()"><span class="unit">/m²</span></div>
            <div class="field-row"><label>Taman/paving</label><input type="number" id="hs_tmn" value="150000" oninput="calcAll()"><span class="unit">/m²</span></div>
            <div class="field-row"><label>Aksesori KM (ls)</label><input type="number" id="hs_akm" value="1500000" oninput="calcAll()"><span class="unit">ls</span></div>
            <div class="field-row"><label>Hardware pintu/jendela</label><input type="number" id="hs_hpj" value="1200000" oninput="calcAll()"><span class="unit">ls</span></div>
            <div class="field-row"><label>Pembersihan akhir</label><input type="number" id="hs_brs" value="2000000" oninput="calcAll()"><span class="unit">ls</span></div>
          </div>
        </div>
        <div class="tbl-wrap"><table class="rtbl" id="tbl11"></table></div>
      </div>
    </div>

    <!-- REKAP -->
    <div id="p_rekap" class="tab-panel">
      <div class="rekap-meta" id="rmeta">Proyek: — | Lokasi: — | Tanggal: —</div>
      <div class="tbl-wrap">
        <table class="rtbl" style="margin-bottom:0">
          <thead><tr><th style="width:28px">No</th><th>Uraian Pekerjaan</th><th class="n" style="width:150px">Biaya (Rp)</th><th class="n" style="width:65px">Proporsi</th></tr></thead>
          <tbody id="rbody"></tbody>
        </table>
      </div>
      <div class="ppn-row">
        <span class="lbl">Sub Total</span><span class="val" id="rksub">Rp 0</span>
        <span class="lbl" style="margin-left:16px">Overhead &amp; Profit</span><span class="val" id="rkoh">Rp 0</span>
        <span class="lbl" style="margin-left:16px">PPN</span><span class="val" id="rkppn">Rp 0</span>
      </div>
      <div class="rekap-total-bar">
        <span class="rtl">Total RAB (termasuk Overhead &amp; PPN)</span>
        <span class="rtv" id="rkgrand">Rp 0</span>
      </div>
      <p id="rknote" style="font-size:11px;color:var(--gray-400);margin-top:10px">*) Estimasi biaya per m²: Rp 0/m²</p>
      <div class="rekap-actions">
        <button class="btn btn-primary" onclick="doPrint()">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Cetak / Export PDF
        </button>
      </div>
    </div>
  </div>

  <footer class="site-footer">
    RABPro &mdash; Kalkulator RAB Rumah &bull; AHSP PUPR 2026 &bull; Koefisien SNI 7394:2008
  </footer>
</div>

<script>
const $=id=>document.getElementById(id);
const v=id=>{const e=$(id);return e?parseFloat(e.value)||0:0};
const fmt=n=>n===0||isNaN(n)?'-':Math.round(n).toLocaleString('id-ID');
const fmtD=(n,d)=>isNaN(n)||n===0?'-':n.toFixed(d);
const fmtM=n=>n<1e6?Math.round(n/1000)+'rb':(n/1e6).toFixed(1)+'jt';
const bkgm=d=>(d*d)/162.2;
let T={};

function sw(name,el){
  document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(t=>t.classList.remove('active'));
  $('p_'+name).classList.add('active');
  el.classList.add('active');
}

function makeTbl(rows){
  let h=`<thead><tr><th style="width:20px"></th><th>Uraian</th><th style="width:70px">Vol</th><th style="width:40px">Sat</th><th style="width:105px">Harga Satuan (Rp)</th><th class="n" style="width:120px">Jumlah (Rp)</th></tr></thead><tbody>`;
  rows.forEach(r=>{
    if(r.type==='hdr') h+=`<tr class="hdr"><td colspan="6">${r.label}</td></tr>`;
    else if(r.type==='sub') h+=`<tr class="sub"><td colspan="5" style="text-align:right;font-size:11px">${r.label} =</td><td class="n">${r.val}</td></tr>`;
    else{
      const ck=r.ck?`<td class="ck">&#10003;</td>`:`<td></td>`;
      h+=`<tr>${ck}<td>${r.lbl}</td><td class="n">${r.vol}</td><td>${r.sat}</td><td>${r.hs}</td><td class="n">${r.jh}</td></tr>`;
    }
  });
  return h+'</tbody>';
}

function c1(){
  const vG=v('g_p')*v('g_l')*v('g_h'), vU=vG*(v('g_uf')/100), vUps=v('g_ups')*v('g_upt');
  const jG=vG*v('hs_gal'),jU=vU*v('hs_uru'),jUps=vUps*v('hs_ups'),jS=v('dur_sta')*v('hs_sta');
  const tot=jG+jU+jUps+jS;
  $('tbl1').innerHTML=makeTbl([
    {type:'hdr',label:'Pekerjaan Tanah'},
    {ck:1,lbl:'Galian tanah biasa',vol:fmtD(vG,2),sat:'m³',hs:fmt(v('hs_gal')),jh:fmt(jG)},
    {ck:1,lbl:'Urugan kembali + pemadatan',vol:fmtD(vU,2),sat:'m³',hs:fmt(v('hs_uru')),jh:fmt(jU)},
    {ck:1,lbl:'Urugan pasir bawah lantai',vol:fmtD(vUps,3),sat:'m³',hs:fmt(v('hs_ups')),jh:fmt(jUps)},
    {lbl:'Sewa stamper',vol:v('dur_sta'),sat:'hr',hs:fmt(v('hs_sta')),jh:fmt(jS)},
    {type:'sub',label:'Total Pekerjaan Tanah',val:fmt(tot)},
  ]);
  $('b1').textContent='Rp '+fmtM(tot); return tot;
}

function c2(){
  const vol=(v('pd_la')+v('pd_lb'))/2*v('pd_h')*v('pd_p');
  const vAan=v('pd_lb')*v('pd_p')*v('pd_at');
  const vBatu=1.2*vol, vSemen=Math.ceil(202*vol/50), vPasir=0.485*vol;
  const vPkj=1.5*vol, vTkg=0.6*vol, vMdr=0.075*vol;
  const jPkj=vPkj*v('hs_p2'),jTkg=vTkg*v('hs_t2'),jMdr=vMdr*v('hs_m2');
  const jBatu=vBatu*v('hs_batu'),jSemen=vSemen*v('hs_spc'),jPasir=vPasir*v('hs_psp'),jAan=vAan*280000;
  const tot=jPkj+jTkg+jMdr+jBatu+jSemen+jPasir+jAan;
  $('tbl2').innerHTML=makeTbl([
    {type:'hdr',label:'Tenaga Kerja (koef. SNI 7394)'},
    {ck:1,lbl:'Pekerja (1.500 OH/m³)',vol:fmtD(vPkj,2),sat:'OH',hs:fmt(v('hs_p2')),jh:fmt(jPkj)},
    {ck:1,lbl:'Tukang batu (0.600 OH/m³)',vol:fmtD(vTkg,2),sat:'OH',hs:fmt(v('hs_t2')),jh:fmt(jTkg)},
    {ck:1,lbl:'Mandor (0.075 OH/m³)',vol:fmtD(vMdr,2),sat:'OH',hs:fmt(v('hs_m2')),jh:fmt(jMdr)},
    {type:'hdr',label:'Bahan'},
    {lbl:'Batu kali (1.200 m³/m³)',vol:fmtD(vBatu,2),sat:'m³',hs:fmt(v('hs_batu')),jh:fmt(jBatu)},
    {lbl:'Semen PC (202 kg/m³ → sak)',vol:vSemen,sat:'sak',hs:fmt(v('hs_spc')),jh:fmt(jSemen)},
    {lbl:'Pasir pasang (0.485 m³/m³)',vol:fmtD(vPasir,2),sat:'m³',hs:fmt(v('hs_psp')),jh:fmt(jPasir)},
    {lbl:'Aanstamping batu kosong',vol:fmtD(vAan,2),sat:'m³',hs:'280,000',jh:fmt(jAan)},
    {type:'sub',label:'Total Pondasi',val:fmt(tot)},
  ]);
  $('b2').textContent='Rp '+fmtM(tot); return tot;
}

function calcBeton(pLen,b,h){
  const cor=b*h*pLen, bek=2*h*pLen;
  const d1=v('st_d1'),nt=v('st_nt'),ds=v('st_ds'),js=v('st_js')/100;
  const nS=Math.ceil(pLen/js), kel=2*(b+h)+0.2;
  const kgTul=bkgm(d1)*nt*pLen, kgSen=bkgm(ds)*nS*kel;
  return{cor,bek,kgTotal:kgTul+kgSen,vS:Math.ceil(336*cor/50),vPas:0.544*cor,vSpl:0.816*cor,vKayu:0.05*bek,vPkj:5.5*cor,vTkg:2.75*cor,vMdr:0.275*cor};
}

function c3(){
  const sl=calcBeton(v('sl_p'),v('sl_b'),v('sl_h'));
  const klLen=v('kl_t')*v('kl_j'), kl=calcBeton(klLen,v('kl_b'),v('kl_b'));
  const rb=calcBeton(v('rb_p'),v('rb_b'),v('rb_h'));
  const cor=sl.cor+kl.cor+rb.cor, bek=sl.bek+kl.bek+rb.bek;
  const kgTot=sl.kgTotal+kl.kgTotal+rb.kgTotal;
  const vPkj=sl.vPkj+kl.vPkj+rb.vPkj, vTkg=sl.vTkg+kl.vTkg+rb.vTkg, vMdr=sl.vMdr+kl.vMdr+rb.vMdr;
  const vSemen=sl.vS+kl.vS+rb.vS, vPas=sl.vPas+kl.vPas+rb.vPas;
  const vSpl=sl.vSpl+kl.vSpl+rb.vSpl, vKayu=sl.vKayu+kl.vKayu+rb.vKayu;
  const jPkj=vPkj*v('hs_p3'),jTkg=vTkg*v('hs_t3'),jMdr=vMdr*v('hs_m3');
  const jBesi=kgTot*v('hs_besi'),jSemen=vSemen*v('hs_spc3'),jPas=vPas*v('hs_pb3');
  const jSpl=vSpl*v('hs_bs3'),jKayu=vKayu*v('hs_kb3');
  const tot=jPkj+jTkg+jMdr+jBesi+jSemen+jPas+jSpl+jKayu;
  $('tbl3').innerHTML=makeTbl([
    {type:'hdr',label:'Tenaga Kerja'},
    {ck:1,lbl:'Pekerja',vol:fmtD(vPkj,2),sat:'OH',hs:fmt(v('hs_p3')),jh:fmt(jPkj)},
    {ck:1,lbl:'Tukang',vol:fmtD(vTkg,2),sat:'OH',hs:fmt(v('hs_t3')),jh:fmt(jTkg)},
    {ck:1,lbl:'Mandor',vol:fmtD(vMdr,2),sat:'OH',hs:fmt(v('hs_m3')),jh:fmt(jMdr)},
    {type:'hdr',label:`Bahan — Beton total: ${fmtD(cor,3)} m³ | Bekisting: ${fmtD(bek,2)} m²`},
    {lbl:`Besi tulangan Ø${v('st_d1')}mm + sengkang`,vol:fmtD(kgTot,1),sat:'kg',hs:fmt(v('hs_besi')),jh:fmt(jBesi)},
    {lbl:'Semen PC',vol:vSemen,sat:'sak',hs:fmt(v('hs_spc3')),jh:fmt(jSemen)},
    {lbl:'Pasir beton',vol:fmtD(vPas,3),sat:'m³',hs:fmt(v('hs_pb3')),jh:fmt(jPas)},
    {lbl:'Batu split 2/3',vol:fmtD(vSpl,3),sat:'m³',hs:fmt(v('hs_bs3')),jh:fmt(jSpl)},
    {lbl:'Kayu bekisting',vol:fmtD(vKayu,3),sat:'m³',hs:fmt(v('hs_kb3')),jh:fmt(jKayu)},
    {type:'sub',label:'Total Struktur Beton',val:fmt(tot)},
  ]);
  $('b3').textContent='Rp '+fmtM(tot); return tot;
}

function c4(){
  const lb=v('dw_lb'),lp=v('dw_lp');
  const jenis=$('dw_jenis').value;
  let vBata=0,jBata=0,lblBata='';
  if(jenis==='bata_merah'){vBata=lb*70;jBata=vBata*v('hs_bm');lblBata='Bata merah (70 bh/m²)';}
  else{vBata=lb*8.33;jBata=vBata*v('hs_hbl');lblBata='Hebel/AAC (8.33 bh/m²)';}
  const vSp=Math.ceil(lb*10/50),jSp=vSp*v('hs_spc4');
  const vPp=lb*0.045,jPp=vPp*v('hs_pp4');
  const vPkj=0.3*lb,vTkg=0.1*lb,jPkj=vPkj*v('hs_p4'),jTkg=vTkg*v('hs_t4');
  const vTkgP=0.15*lp,jTkgP=vTkgP*v('hs_tp4');
  const jSpP=Math.ceil(lp*6.24/50)*v('hs_spc4'), jPpP=lp*0.018*v('hs_pp4');
  const tot=jBata+jSp+jPp+jPkj+jTkg+jTkgP+jSpP+jPpP;
  $('tbl4').innerHTML=makeTbl([
    {type:'hdr',label:'Pasangan Bata'},
    {ck:1,lbl:lblBata,vol:Math.round(vBata),sat:'bh',hs:fmt(jenis==='bata_merah'?v('hs_bm'):v('hs_hbl')),jh:fmt(jBata)},
    {lbl:'Semen PC',vol:vSp,sat:'sak',hs:fmt(v('hs_spc4')),jh:fmt(jSp)},
    {lbl:'Pasir pasang',vol:fmtD(vPp,3),sat:'m³',hs:fmt(v('hs_pp4')),jh:fmt(jPp)},
    {ck:1,lbl:'Tukang bata',vol:fmtD(vTkg,2),sat:'OH',hs:fmt(v('hs_t4')),jh:fmt(jTkg)},
    {ck:1,lbl:'Pekerja pasang',vol:fmtD(vPkj,2),sat:'OH',hs:fmt(v('hs_p4')),jh:fmt(jPkj)},
    {type:'hdr',label:'Plesteran & Acian'},
    {ck:1,lbl:'Tukang plester',vol:fmtD(vTkgP,2),sat:'OH',hs:fmt(v('hs_tp4')),jh:fmt(jTkgP)},
    {lbl:'Semen plester',vol:Math.ceil(lp*6.24/50),sat:'sak',hs:fmt(v('hs_spc4')),jh:fmt(jSpP)},
    {lbl:'Pasir plester',vol:fmtD(lp*0.018,3),sat:'m³',hs:fmt(v('hs_pp4')),jh:fmt(jPpP)},
    {type:'sub',label:'Total Dinding',val:fmt(tot)},
  ]);
  $('b4').textContent='Rp '+fmtM(tot); return tot;
}

function c5(){
  const la=v('at_la'),jR=$('at_jenis').value,jP=$('at_pjenis').value;
  const hsR=jR==='kayu'?v('hs_rk'):v('hs_rb');
  const jRangka=la*hsR, jUpR=la*v('hs_ur'), jUpA=la*v('hs_ua');
  let jPenutup=0,lblP='',volP=0;
  if(jP==='genteng_tanah'){volP=la*25;jPenutup=volP*v('hs_gt');lblP='Genteng tanah (25 bh/m²)';}
  else if(jP==='genteng_beton'){volP=la*12;jPenutup=volP*v('hs_gb');lblP='Genteng beton (12 bh/m²)';}
  else{volP=la;jPenutup=volP*v('hs_sp');lblP='Spandek/metal';}
  const jNok=v('at_nok')*v('hs_nok'), jLsp=v('at_ls')*v('hs_lsp');
  const tot=jRangka+jPenutup+jNok+jLsp+jUpR+jUpA;
  $('tbl5').innerHTML=makeTbl([
    {type:'hdr',label:'Rangka Atap'},
    {lbl:(jR==='kayu'?'Rangka kayu':'Rangka baja ringan')+` (${la} m²)`,vol:fmtD(la,1),sat:'m²',hs:fmt(hsR),jh:fmt(jRangka)},
    {ck:1,lbl:'Upah pasang rangka',vol:fmtD(la,1),sat:'m²',hs:fmt(v('hs_ur')),jh:fmt(jUpR)},
    {type:'hdr',label:'Penutup Atap'},
    {lbl:lblP,vol:fmt(volP),sat:jP==='spandek'?'m²':'bh',hs:fmt(jP==='genteng_tanah'?v('hs_gt'):jP==='genteng_beton'?v('hs_gb'):v('hs_sp')),jh:fmt(jPenutup)},
    {lbl:'Nok/bubung',vol:v('at_nok'),sat:'m',hs:fmt(v('hs_nok')),jh:fmt(jNok)},
    {lbl:'Lisplank kayu',vol:v('at_ls'),sat:'m',hs:fmt(v('hs_lsp')),jh:fmt(jLsp)},
    {ck:1,lbl:'Upah pasang penutup',vol:fmtD(la,1),sat:'m²',hs:fmt(v('hs_ua')),jh:fmt(jUpA)},
    {type:'sub',label:'Total Atap',val:fmt(tot)},
  ]);
  $('b5').textContent='Rp '+fmtM(tot); return tot;
}

function c6(){
  const jR=$('lt_jr').value;
  let hsKer=v('hs_k40'),lblK='Keramik 40×40';
  if(jR==='60'){hsKer=v('hs_k60');lblK='Keramik 60×60';}
  else if(jR==='granit'){hsKer=v('hs_kgr');lblK='Granit';}
  const lr=v('lt_lr'),lk=v('lt_lk'),ls=v('lt_ls');
  const jKer=lr*hsKer, jKerKM=lk*v('hs_kkm');
  const jUp=(lr+lk)*v('hs_up6');
  const vSp=Math.ceil((lr+lk)*5.04/50),jSp=vSp*v('hs_spc6');
  const vPas=(lr+lk)*0.045,jPas=vPas*v('hs_ps6');
  const jScr=ls*v('hs_us6'), jSpcScr=Math.ceil(ls*0.06*336/50)*v('hs_spc6');
  const tot=jKer+jKerKM+jUp+jSp+jPas+jScr+jSpcScr;
  $('tbl6').innerHTML=makeTbl([
    {type:'hdr',label:'Lantai Ruangan'},
    {lbl:lblK,vol:fmtD(lr,1),sat:'m²',hs:fmt(hsKer),jh:fmt(jKer)},
    {lbl:'Keramik kamar mandi',vol:fmtD(lk,1),sat:'m²',hs:fmt(v('hs_kkm')),jh:fmt(jKerKM)},
    {lbl:'Semen PC (5.04 kg/m²)',vol:vSp,sat:'sak',hs:fmt(v('hs_spc6')),jh:fmt(jSp)},
    {lbl:'Pasir pasang',vol:fmtD(vPas,3),sat:'m³',hs:fmt(v('hs_ps6')),jh:fmt(jPas)},
    {ck:1,lbl:'Upah pasang keramik',vol:fmtD(lr+lk,1),sat:'m²',hs:fmt(v('hs_up6')),jh:fmt(jUp)},
    {type:'hdr',label:'Screed / Rabat Beton'},
    {ck:1,lbl:'Upah screed beton',vol:fmtD(ls,1),sat:'m²',hs:fmt(v('hs_us6')),jh:fmt(jScr)},
    {lbl:'Semen PC screed',vol:Math.ceil(ls*0.06*336/50),sat:'sak',hs:fmt(v('hs_spc6')),jh:fmt(jSpcScr)},
    {type:'sub',label:'Total Lantai',val:fmt(tot)},
  ]);
  $('b6').textContent='Rp '+fmtM(tot); return tot;
}

function c7(){
  const lp=v('pf_lp'),jp=$('pf_jp').value;
  let hsMat=v('hs_grc'),lblM='GRC board';
  if(jp==='gypsum'){hsMat=v('hs_gyp');lblM='Gypsum board';}
  else if(jp==='triplex'){hsMat=v('hs_trp');lblM='Triplek 6mm';}
  const jMat=lp*hsMat, jRangka=lp*v('hs_rhm'), jList=v('pf_ls')*v('hs_lst'), jUp=lp*v('hs_upp7');
  const tot=jMat+jRangka+jList+jUp;
  $('tbl7').innerHTML=makeTbl([
    {lbl:lblM,vol:fmtD(lp,1),sat:'m²',hs:fmt(hsMat),jh:fmt(jMat)},
    {lbl:'Rangka hollow metal',vol:fmtD(lp,1),sat:'m²',hs:fmt(v('hs_rhm')),jh:fmt(jRangka)},
    {lbl:'List profil plafon',vol:v('pf_ls'),sat:'m',hs:fmt(v('hs_lst')),jh:fmt(jList)},
    {ck:1,lbl:'Upah pasang plafon',vol:fmtD(lp,1),sat:'m²',hs:fmt(v('hs_upp7')),jh:fmt(jUp)},
    {type:'sub',label:'Total Plafon',val:fmt(tot)},
  ]);
  $('b7').textContent='Rp '+fmtM(tot); return tot;
}

function c8(){
  const bPU=v('kp_pu')*v('hs_pu'),bPK=v('kp_pk')*v('hs_pk'),bPKM=v('kp_pkm')*v('hs_pkm');
  const bJB=v('kp_jb')*v('hs_jb'),bJK=v('kp_jk')*v('hs_jk'),bBV=v('kp_bv')*v('hs_bv');
  const bUp=v('hs_upkp');
  const tot=bPU+bPK+bPKM+bJB+bJK+bBV+bUp;
  $('tbl8').innerHTML=makeTbl([
    {type:'hdr',label:'Pintu (set lengkap + kusen)'},
    {lbl:'Pintu utama',vol:v('kp_pu'),sat:'unit',hs:fmt(v('hs_pu')),jh:fmt(bPU)},
    {lbl:'Pintu kamar',vol:v('kp_pk'),sat:'unit',hs:fmt(v('hs_pk')),jh:fmt(bPK)},
    {lbl:'Pintu KM/WC',vol:v('kp_pkm'),sat:'unit',hs:fmt(v('hs_pkm')),jh:fmt(bPKM)},
    {type:'hdr',label:'Jendela & Ventilasi'},
    {lbl:'Jendela besar 1×1.2m',vol:v('kp_jb'),sat:'unit',hs:fmt(v('hs_jb')),jh:fmt(bJB)},
    {lbl:'Jendela kecil 0.6×0.8m',vol:v('kp_jk'),sat:'unit',hs:fmt(v('hs_jk')),jh:fmt(bJK)},
    {lbl:'Boven/ventilasi',vol:v('kp_bv'),sat:'unit',hs:fmt(v('hs_bv')),jh:fmt(bBV)},
    {ck:1,lbl:'Upah pasang (ls)',vol:1,sat:'ls',hs:fmt(v('hs_upkp')),jh:fmt(bUp)},
    {type:'sub',label:'Total Kusen/Pintu/Jendela',val:fmt(tot)},
  ]);
  $('b8').textContent='Rp '+fmtM(tot); return tot;
}

function c9(){
  const bKD=v('sa_kd')*v('hs_kd'),bKJ=v('sa_kj')*v('hs_kj'),bWS=v('sa_ws')*v('hs_ws');
  const bSH=v('sa_sh')*v('hs_sh'),bKS=v('sa_ks')*v('hs_ks'),bST=v('sa_st')*v('hs_st');
  const bSP=v('sa_sp')*v('hs_sp9'),bTA=v('sa_ta')*v('hs_ta');
  const bPB=v('sa_pb')*v('hs_ppb'),bPK=v('sa_pk')*v('hs_ppk'),bUIS=v('hs_uis');
  const tot=bKD+bKJ+bWS+bSH+bKS+bST+bSP+bTA+bPB+bPK+bUIS;
  $('tbl9').innerHTML=makeTbl([
    {type:'hdr',label:'Sanitasi Kamar Mandi'},
    {lbl:'Kloset duduk',vol:v('sa_kd'),sat:'unit',hs:fmt(v('hs_kd')),jh:fmt(bKD)},
    {lbl:'Kloset jongkok',vol:v('sa_kj'),sat:'unit',hs:fmt(v('hs_kj')),jh:fmt(bKJ)},
    {lbl:'Wastafel',vol:v('sa_ws'),sat:'unit',hs:fmt(v('hs_ws')),jh:fmt(bWS)},
    {lbl:'Shower set',vol:v('sa_sh'),sat:'unit',hs:fmt(v('hs_sh')),jh:fmt(bSH)},
    {type:'hdr',label:'Utilitas'},
    {lbl:'Kitchen sink',vol:v('sa_ks'),sat:'unit',hs:fmt(v('hs_ks')),jh:fmt(bKS)},
    {lbl:'Septictank bio',vol:v('sa_st'),sat:'unit',hs:fmt(v('hs_st')),jh:fmt(bST)},
    {lbl:'Sumur bor + pompa',vol:v('sa_sp'),sat:'unit',hs:fmt(v('hs_sp9')),jh:fmt(bSP)},
    {lbl:'Tandon air 1000L',vol:v('sa_ta'),sat:'unit',hs:fmt(v('hs_ta')),jh:fmt(bTA)},
    {lbl:'Pipa air bersih PVC',vol:v('sa_pb'),sat:'m',hs:fmt(v('hs_ppb')),jh:fmt(bPB)},
    {lbl:'Pipa air kotor PVC',vol:v('sa_pk'),sat:'m',hs:fmt(v('hs_ppk')),jh:fmt(bPK)},
    {ck:1,lbl:'Upah instalasi plumbing',vol:1,sat:'ls',hs:fmt(v('hs_uis')),jh:fmt(bUIS)},
    {type:'sub',label:'Total Sanitasi & Plumbing',val:fmt(tot)},
  ]);
  $('b9').textContent='Rp '+fmtM(tot); return tot;
}

function c10(){
  const bTL=v('el_tl')*v('hs_tl'),bSK=v('el_sk')*v('hs_sk'),bSL=v('el_sl')*v('hs_sl');
  const bPB=v('el_pb')*v('hs_pb10'),bKBL=v('el_kbl')*v('hs_kbl');
  const bPLN=v('hs_pln'),bPP=v('el_pp')*v('hs_pp10');
  const tot=bTL+bSK+bSL+bPB+bKBL+bPLN+bPP;
  $('tbl10').innerHTML=makeTbl([
    {type:'hdr',label:`Instalasi Listrik — ${v('el_daya')} VA`},
    {ck:1,lbl:'Titik lampu (instalasi + fitting)',vol:v('el_tl'),sat:'ttk',hs:fmt(v('hs_tl')),jh:fmt(bTL)},
    {ck:1,lbl:'Stop kontak',vol:v('el_sk'),sat:'ttk',hs:fmt(v('hs_sk')),jh:fmt(bSK)},
    {ck:1,lbl:'Saklar',vol:v('el_sl'),sat:'ttk',hs:fmt(v('hs_sl')),jh:fmt(bSL)},
    {lbl:'Panel box / MCB',vol:v('el_pb'),sat:'unit',hs:fmt(v('hs_pb10')),jh:fmt(bPB)},
    {lbl:'Kabel NYM 2×2.5mm',vol:v('el_kbl'),sat:'m',hs:fmt(v('hs_kbl')),jh:fmt(bKBL)},
    {lbl:'Biaya pasang PLN / SLO',vol:1,sat:'ls',hs:fmt(v('hs_pln')),jh:fmt(bPLN)},
    {lbl:'Penangkal petir',vol:v('el_pp'),sat:'set',hs:fmt(v('hs_pp10')),jh:fmt(bPP)},
    {type:'sub',label:'Total Listrik & MEP',val:fmt(tot)},
  ]);
  $('b10').textContent='Rp '+fmtM(tot); return tot;
}

function c11(){
  const bCDL=v('fi_cdl')*v('hs_cdl'),bCDD=v('fi_cdd')*v('hs_cdd'),bCP=v('fi_cp')*v('hs_cpp');
  const bWF=v('fi_wf')*v('hs_wf');
  const bPGR=v('fi_pp')*v('hs_pgr'),bCPT=v('fi_cp2')*v('hs_cpt'),bTM=v('fi_tm')*v('hs_tmn');
  const bAKM=v('hs_akm'),bHPJ=v('hs_hpj'),bBRS=v('hs_brs');
  const tot=bCDL+bCDD+bCP+bWF+bPGR+bCPT+bTM+bAKM+bHPJ+bBRS;
  $('tbl11').innerHTML=makeTbl([
    {type:'hdr',label:'Pengecatan'},
    {lbl:'Cat dinding luar (2 lapis)',vol:v('fi_cdl'),sat:'m²',hs:fmt(v('hs_cdl')),jh:fmt(bCDL)},
    {lbl:'Cat dinding dalam (2 lapis)',vol:v('fi_cdd'),sat:'m²',hs:fmt(v('hs_cdd')),jh:fmt(bCDD)},
    {lbl:'Cat plafon',vol:v('fi_cp'),sat:'m²',hs:fmt(v('hs_cpp')),jh:fmt(bCP)},
    {type:'hdr',label:'Waterproofing'},
    {lbl:'Waterproofing area basah',vol:v('fi_wf'),sat:'m²',hs:fmt(v('hs_wf')),jh:fmt(bWF)},
    {type:'hdr',label:'Pagar & Pekerjaan Luar'},
    {lbl:'Pagar bata + besi hollow',vol:v('fi_pp'),sat:'m',hs:fmt(v('hs_pgr')),jh:fmt(bPGR)},
    {lbl:'Carport rabat beton',vol:v('fi_cp2'),sat:'m²',hs:fmt(v('hs_cpt')),jh:fmt(bCPT)},
    {lbl:'Taman / perkerasan paving',vol:v('fi_tm'),sat:'m²',hs:fmt(v('hs_tmn')),jh:fmt(bTM)},
    {type:'hdr',label:'Aksesori & Lain-lain'},
    {lbl:'Aksesori kamar mandi (ls)',vol:1,sat:'ls',hs:fmt(v('hs_akm')),jh:fmt(bAKM)},
    {lbl:'Hardware pintu & jendela (ls)',vol:1,sat:'ls',hs:fmt(v('hs_hpj')),jh:fmt(bHPJ)},
    {lbl:'Pembersihan akhir (ls)',vol:1,sat:'ls',hs:fmt(v('hs_brs')),jh:fmt(bBRS)},
    {type:'sub',label:'Total Finishing & Pek. Luar',val:fmt(tot)},
  ]);
  $('b11').textContent='Rp '+fmtM(tot); return tot;
}

const LABELS=['Pekerjaan Tanah','Pondasi Batu Kali','Struktur Beton','Dinding & Plester','Atap','Lantai','Plafon','Kusen/Pintu/Jendela','Sanitasi & Plumbing','Listrik & MEP','Finishing & Pek. Luar'];
const SHORT=['Tanah','Pondasi','Struktur','Dinding','Atap','Lantai','Plafon','Pintu/Jendela','Sanitasi','Listrik','Finishing'];

function updateSummary(grand){
  const keys=[T.t1,T.t2,T.t3,T.t4,T.t5,T.t6,T.t7,T.t8,T.t9,T.t10,T.t11];
  let h='';
  SHORT.forEach((s,i)=>h+=`<div class="sum-card"><div class="sc-label">${s}</div><div class="sc-val">Rp ${fmtM(keys[i])}</div></div>`);
  h+=`<div class="sum-card accent"><div class="sc-label">Total RAB</div><div class="sc-val">Rp ${fmtM(grand)}</div></div>`;
  $('sumgrid').innerHTML=h;
  $('pgbar').style.width=Math.min(100,grand/500000000*100)+'%';
}

function updateRekap(){
  const sub=Object.values(T).reduce((a,b)=>a+b,0);
  const oh=sub*(v('ohp')/100), ppn=(sub+oh)*(v('ppnp')/100), grand=sub+oh+ppn;
  let rb='';
  LABELS.forEach((lbl,i)=>{
    const val=[T.t1,T.t2,T.t3,T.t4,T.t5,T.t6,T.t7,T.t8,T.t9,T.t10,T.t11][i];
    const pct=sub>0?((val/sub)*100).toFixed(1):'0.0';
    const bw=sub>0?Math.round(val/sub*100):0;
    rb+=`<tr><td style="font-size:11px;color:var(--gray-400)">${i+1}</td>
    <td style="font-size:12px">${lbl}<div class="bar-mini"><div class="bar-fill" style="width:${bw}%"></div></div></td>
    <td class="n" style="font-size:12px">${fmt(val)}</td>
    <td class="n" style="font-size:11px;color:var(--gray-400)">${pct}%</td></tr>`;
  });
  rb+=`<tr class="sub"><td></td><td>Jumlah Biaya Pekerjaan</td><td class="n">${fmt(sub)}</td><td></td></tr>`;
  $('rbody').innerHTML=rb;
  $('rksub').textContent='Rp '+fmt(sub);
  $('rkoh').textContent='Rp '+fmt(oh);
  $('rkppn').textContent='Rp '+fmt(ppn);
  $('rkgrand').textContent='Rp '+Math.round(grand).toLocaleString('id-ID');
  const lb=v('lb')||1;
  $('rknote').textContent=`*) Estimasi biaya per m² luas bangunan: Rp ${Math.round(grand/lb).toLocaleString('id-ID')}/m² (luas: ${lb} m²)`;
  updateMeta();
  return grand;
}

function updateMeta(){
  const n=$('pn').value||'-', l=$('pl').value||'-', d=$('pd').value||'-';
  const m=$('rmeta');
  if(m) m.textContent=`Proyek: ${n} | Lokasi: ${l} | Tanggal: ${d} | Pemilik: ${$('po').value||'-'}`;
}

function calcAll(){
  T.t1=c1();T.t2=c2();T.t3=c3();T.t4=c4();T.t5=c5();
  T.t6=c6();T.t7=c7();T.t8=c8();T.t9=c9();T.t10=c10();T.t11=c11();
  const g=updateRekap();
  updateSummary(g);
}

function doReset(){
  if(!confirm('Reset semua input ke nilai default?')) return;
  document.querySelectorAll('input[type=number]').forEach(el=>{if(el.defaultValue)el.value=el.defaultValue});
  calcAll();
}

function doPrint(){
  const n=$('pn').value||'RAB', l=$('pl').value, d=$('pd').value, o=$('po').value;
  const oh=v('ohp'), ppn=v('ppnp');
  const sub=Object.values(T).reduce((a,b)=>a+b,0);
  const ohV=sub*(oh/100), ppnV=(sub+ohV)*(ppn/100), grand=sub+ohV+ppnV;
  const vals=[T.t1,T.t2,T.t3,T.t4,T.t5,T.t6,T.t7,T.t8,T.t9,T.t10,T.t11];
  const rows=LABELS.map((lbl,i)=>`<tr><td>${i+1}</td><td>${lbl}</td><td style="text-align:right">${fmt(vals[i])}</td></tr>`).join('');
  const html=`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>RAB - ${n}</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@700&display=swap');
    body{font-family:'Inter',sans-serif;font-size:12px;color:#202124;max-width:750px;margin:30px auto;padding:24px}
    .header{border-bottom:2px solid #1a9e6f;padding-bottom:12px;margin-bottom:20px}
    .logo{display:inline-block;background:#1a9e6f;color:#fff;font-family:'Plus Jakarta Sans',sans-serif;font-size:12px;padding:4px 10px;border-radius:5px;margin-bottom:8px}
    h2{font-family:'Plus Jakarta Sans',sans-serif;font-size:18px;margin:0 0 4px}
    .meta{font-size:11px;color:#5f6368}
    table{width:100%;border-collapse:collapse;margin-bottom:16px}
    th{text-align:left;padding:7px 10px;font-size:10px;font-weight:600;color:#5f6368;text-transform:uppercase;letter-spacing:.04em;border-bottom:1px solid #e8eaed;background:#f8f9fa}
    td{padding:6px 10px;border-bottom:1px solid #f1f3f4}
    td.n{text-align:right;font-weight:500}
    .sub{background:#f8f9fa;font-weight:600}
    .sub td{border-top:1px solid #e8eaed}
    .oh td{font-size:11px;color:#5f6368}
    .grand{background:#1a9e6f}
    .grand td{color:#fff;font-weight:700;font-size:13px;border:none}
    .footer{color:#9aa0a6;font-size:10px;margin-top:20px;text-align:center;border-top:1px solid #e8eaed;padding-top:12px}
    @media print{body{margin:0}button{display:none}}
  </style></head><body>
  <div class="header">
    <div class="logo">RABPro</div>
    <h2>Rencana Anggaran Biaya (RAB)</h2>
    <div class="meta">${n} &bull; ${l} &bull; Pemilik: ${o} &bull; Tanggal: ${d}</div>
  </div>
  <table>
    <thead><tr><th>No</th><th>Uraian Pekerjaan</th><th style="text-align:right">Biaya (Rp)</th></tr></thead>
    <tbody>
    ${rows}
    <tr class="sub"><td colspan="2" style="text-align:right">Jumlah Pekerjaan</td><td class="n">${fmt(sub)}</td></tr>
    <tr class="oh"><td colspan="2" style="text-align:right">Overhead &amp; Profit (${oh}%)</td><td class="n">${fmt(ohV)}</td></tr>
    <tr class="oh"><td colspan="2" style="text-align:right">PPN (${ppn}%)</td><td class="n">${fmt(ppnV)}</td></tr>
    <tr class="grand"><td colspan="2">TOTAL RAB</td><td class="n">Rp ${Math.round(grand).toLocaleString('id-ID')}</td></tr>
    </tbody>
  </table>
  <div class="footer">
    Estimasi biaya per m²: Rp ${Math.round(grand/(v('lb')||1)).toLocaleString('id-ID')}/m² &bull;
    AHSP PUPR 2026 &bull; Koefisien SNI 7394:2008 &bull; Dibuat dengan RABPro
  </div>
  <script>window.onload=function(){window.print()}<\/script>
  </body></html>`;
  const w=window.open('','_blank');
  if(w){w.document.write(html);w.document.close();}
}

// Init
const dt=new Date(); $('pd').value=dt.toISOString().split('T')[0];
calcAll();
</script>
</body>
</html>
