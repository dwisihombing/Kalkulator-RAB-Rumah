<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RABPro — Kalkulator RAB Rumah</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@600;700&display=swap" rel="stylesheet">
<style>
:root {
  --green: #1a9e6f;
  --green-d: #0f7a54;
  --green-l: #e8f7f1;
  --green-t: #0a5e3f;
  --gray-50: #f8f9fa;
  --gray-100: #f1f3f4;
  --gray-200: #e8eaed;
  --gray-400: #9aa0a6;
  --gray-600: #5f6368;
  --gray-800: #202124;
  --white: #ffffff;
  --shadow-sm: 0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.06);
  --shadow-md: 0 4px 12px rgba(0,0,0,.1), 0 2px 4px rgba(0,0,0,.06);
  --radius: 10px;
  --radius-lg: 14px;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Inter',sans-serif;background:var(--gray-50);color:var(--gray-800);font-size:13px;min-height:100vh}
a{color:var(--green);text-decoration:none}

/* HEADER */
.site-header{background:var(--white);border-bottom:1px solid var(--gray-200);padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;box-shadow:var(--shadow-sm)}
.brand{display:flex;align-items:center;gap:10px}
.brand-logo{background:var(--green);color:#fff;font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:13px;padding:5px 10px;border-radius:6px;letter-spacing:.3px}
.brand-name{font-family:'Plus Jakarta Sans',sans-serif;font-weight:700;font-size:15px;color:var(--gray-800)}
.brand-sub{font-size:11px;color:var(--gray-400);margin-left:4px}
.header-right{display:flex;gap:8px;align-items:center}
.btn{display:inline-flex;align-items:center;gap:5px;padding:7px 14px;border-radius:8px;font-size:12px;font-weight:500;cursor:pointer;border:1px solid var(--gray-200);background:var(--white);color:var(--gray-600);transition:all .15s}
.btn:hover{background:var(--gray-100);border-color:var(--gray-400)}
.btn-primary{background:var(--green);color:#fff;border-color:var(--green)}
.btn-primary:hover{background:var(--green-d);border-color:var(--green-d)}
.btn svg{width:14px;height:14px;flex-shrink:0}

/* LAYOUT */
.container{max-width:1080px;margin:0 auto;padding:20px 16px}

/* PROJECT INFO */
.proj-card{background:var(--white);border-radius:var(--radius-lg);border:1px solid var(--gray-200);padding:16px 20px;margin-bottom:16px;box-shadow:var(--shadow-sm)}
.proj-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px}
.pi{display:flex;flex-direction:column;gap:3px}
.pi label{font-size:10px;font-weight:600;color:var(--gray-400);text-transform:uppercase;letter-spacing:.05em}
.pi input,.pi select{border:none;border-bottom:1.5px solid var(--gray-200);padding:3px 0;font-size:12px;font-weight:500;color:var(--gray-800);background:transparent;outline:none;font-family:'Inter',sans-serif;transition:border-color .15s}
.pi input:focus,.pi select:focus{border-bottom-color:var(--green)}

/* SUMMARY CARDS */
.summary-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(110px,1fr));gap:8px;margin-bottom:16px}
.sum-card{background:var(--white);border-radius:var(--radius);border:1px solid var(--gray-200);padding:12px 14px;box-shadow:var(--shadow-sm)}
.sum-card.accent{background:var(--green);border-color:var(--green-d)}
.sum-card .sc-label{font-size:10px;font-weight:600;color:var(--gray-400);text-transform:uppercase;letter-spacing:.04em;margin-bottom:4px}
.sum-card .sc-val{font-size:14px;font-weight:600;color:var(--gray-800)}
.sum-card.accent .sc-label{color:rgba(255,255,255,.75)}
.sum-card.accent .sc-val{color:#fff;font-size:15px}
.prog-wrap{background:var(--gray-100);height:4px;border-radius:2px;overflow:hidden;margin-bottom:16px}
.prog-bar{height:100%;background:var(--green);border-radius:2px;transition:width .5s ease}

/* TABS */
.tabs-wrap{background:var(--white);border-radius:var(--radius-lg);border:1px solid var(--gray-200);box-shadow:var(--shadow-sm);overflow:hidden}
.tabs-nav{display:flex;overflow-x:auto;border-bottom:1px solid var(--gray-200);scrollbar-width:none;background:var(--gray-50)}
.tabs-nav::-webkit-scrollbar{display:none}
.tab-btn{flex-shrink:0;padding:11px 16px;font-size:11.5px;font-weight:500;color:var(--gray-600);cursor:pointer;border:none;background:transparent;border-bottom:2px solid transparent;margin-bottom:-1px;white-space:nowrap;transition:all .15s;font-family:'Inter',sans-serif}
.tab-btn:hover{color:var(--gray-800);background:var(--gray-100)}
.tab-btn.active{color:var(--green);border-bottom-color:var(--green);background:var(--white);font-weight:600}
.tab-panel{display:none;padding:20px}
.tab-panel.active{display:block}

/* SECTION CARD */
.sec-card{background:var(--gray-50);border-radius:var(--radius);border:1px solid var(--gray-200);overflow:hidden;margin-bottom:12px}
.sec-head{background:var(--green);padding:10px 16px;display:flex;align-items:center;gap:8px}
.sec-head .sn{background:rgba(255,255,255,.25);color:#fff;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;font-family:'Plus Jakarta Sans',sans-serif}
.sec-head .st{font-size:12px;font-weight:600;color:#fff;font-family:'Plus Jakarta Sans',sans-serif}
.sec-head .sb{margin-left:auto;font-size:11px;color:rgba(255,255,255,.9);font-weight:500}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:0}
@media(max-width:600px){.two-col{grid-template-columns:1fr}}
.col-pane{padding:14px 16px;background:var(--white)}
.col-pane:first-child{border-right:1px solid var(--gray-200)}
.sub-label{font-size:10px;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.06em;margin-bottom:8px}
.field-row{display:grid;grid-template-columns:1fr 80px 28px;gap:4px;align-items:center;margin-bottom:6px}
.field-row label{font-size:11px;color:var(--gray-600)}
.field-row input,.field-row select{font-size:11px;padding:3px 6px;border:1px solid var(--gray-200);border-radius:5px;background:var(--white);color:var(--gray-800);text-align:right;width:100%;outline:none;font-family:'Inter',sans-serif;transition:border-color .15s}
.field-row input:focus,.field-row select:focus{border-color:var(--green)}
.field-row input[readonly]{background:var(--gray-50);color:var(--gray-400);cursor:default}
.field-row .unit{font-size:10px;color:var(--gray-400);text-align:left}
.divline{border:none;border-top:1px solid var(--gray-200);margin:8px 0}

/* TABLE */
.tbl-wrap{overflow-x:auto}
table.rtbl{width:100%;border-collapse:collapse;font-size:11px;table-layout:fixed}
table.rtbl th{text-align:left;padding:8px 10px;font-size:10px;font-weight:700;color:var(--gray-400);text-transform:uppercase;letter-spacing:.04em;border-bottom:1px solid var(--gray-200);background:var(--gray-50)}
table.rtbl td{padding:6px 10px;border-bottom:1px solid var(--gray-100);color:var(--gray-800);overflow:hidden;text-overflow:ellipsis;vertical-align:middle}
table.rtbl td.n{text-align:right;font-variant-numeric:tabular-nums;white-space:nowrap;font-weight:500}
table.rtbl tr:last-child td{border-bottom:none}
table.rtbl .hdr td{background:var(--gray-50);font-weight:700;font-size:10px;color:var(--gray-400);text-transform:uppercase;letter-spacing:.04em;padding:6px 10px}
table.rtbl .sub td{background:var(--gray-50);font-weight:600;font-size:11px}
table.rtbl .grand td{background:var(--green);color:#fff;font-weight:700;font-size:12px}
table.rtbl tr:hover td{background:var(--gray-50)}
table.rtbl .grand:hover td{background:var(--green-d)}
.ck{color:var(--green);font-size:13px;width:20px}
.hi{width:100px;font-size:11px;padding:3px 6px;border:1px solid var(--gray-200);border-radius:5px;background:var(--white);color:var(--gray-800);text-align:right;font-family:'Inter',sans-serif;outline:none;transition:border-color .15s}
.hi:focus{border-color:var(--green)}

/* REKAP */
.rekap-meta{font-size:11px;color:var(--gray-400);margin-bottom:14px;padding:10px 14px;background:var(--gray-50);border-radius:8px;border:1px solid var(--gray-200)}
.rekap-total-bar{background:var(--green);border-radius:var(--radius);padding:14px 18px;display:flex;justify-content:space-between;align-items:center;margin-top:4px}
.rekap-total-bar .rtl{color:rgba(255,255,255,.85);font-size:12px;font-weight:500}
.rekap-total-bar .rtv{color:#fff;font-size:18px;font-weight:700;font-family:'Plus Jakarta Sans',sans-serif}
.ppn-row{display:flex;align-items:center;gap:12px;padding:12px 0;flex-wrap:wrap;border-top:1px solid var(--gray-200);margin-top:8px}
.ppn-row span.lbl{font-size:11px;color:var(--gray-400)}
.ppn-row span.val{font-size:12px;font-weight:600;color:var(--gray-800)}
.bar-mini{background:var(--gray-100);border-radius:2px;height:4px;overflow:hidden;margin-top:3px}
.bar-fill{height:100%;background:var(--green);border-radius:2px;transition:width .4s}
.rekap-actions{display:flex;gap:8px;flex-wrap:wrap;margin-top:16px}

/* FOOTER */
.site-footer{text-align:center;padding:24px;color:var(--gray-400);font-size:11px;margin-top:20px}
.site-footer a{color:var(--gray-400)}

/* RESPONSIVE */
@media(max-width:480px){
  .brand-sub,.header-right .btn:not(.btn-primary){display:none}
  .tab-btn{font-size:11px;padding:9px 12px}
}
@media print{
  .site-header,.tabs-nav,.proj-card,.summary-grid,.prog-wrap,.rekap-actions{display:none}
  .tabs-wrap{box-shadow:none;border:none}
  .tab-panel{display:block!important;padding:0}
}
</style>
</head>
<body>

<header class="site-header">
  <div class="brand">
    <span class="brand-logo">RABPro</span>
    <span class="brand-name">Kalkulator RAB Rumah</span>
    <span class="brand-sub">AHSP PUPR 2026</span>
  </div>
  <div class="header-right">
    <button class="btn" onclick="doReset()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
      Reset
    </button>
    <button class="btn btn-primary" onclick="doPrint()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
      Cetak PDF
    </button>
  </div>
</header>

<div class="container">

  <!-- PROJECT INFO -->
  <div class="proj-card">
    <div class="proj-grid">
      <div class="pi"><label>Nama Proyek</label><input id="pn" value="Rumah Tinggal Type 36" oninput="updateMeta()"></div>
      <div class="pi"><label>Lokasi</label><input id="pl" value="Jakarta" oninput="updateMeta()"></div>
      <div class="pi"><label>Pemilik</label><input id="po" value="-" oninput="updateMeta()"></div>
      <div class="pi"><label>Tanggal</label><input type="date" id="pd" oninput="updateMeta()"></div>
      <div class="pi"><label>Luas Bangunan (m²)</label><input type="number" id="lb" value="36" oninput="calcAll()"></div>
      <div class="pi"><label>Overhead + Profit (%)</label><input type="number" id="ohp" value="15" oninput="calcAll()"></div>
      <div class="pi"><label>PPN (%)</label><input type="number" id="ppnp" value="11" oninput="calcAll()"></div>
    </div>
  </div>

  <!-- SUMMARY -->
  <div class="summary-grid" id="sumgrid"></div>
  <div class="prog-wrap"><div class="prog-bar" id="pgbar" style="width:0%"></div></div>

  <!-- TABS -->
  <div class="tabs-wrap">
    <div class="tabs-nav">
      <button class="tab-btn active" onclick="sw('tanah',this)">1. Tanah</button>
      <button class="tab-btn" onclick="sw('pondasi',this)">2. Pondasi</button>
      <button class="tab-btn" onclick="sw('struktur',this)">3. Struktur</button>
      <button class="tab-btn" onclick="sw('dinding',this)">4. Dinding</button>
      <button class="tab-btn" onclick="sw('atap',this)">5. Atap</button>
      <button class="tab-btn" onclick="sw('lantai',this)">6. Lantai</button>
      <button class="tab-btn" onclick="sw('plafon',this)">7. Plafon</button>
      <button class="tab-btn" onclick="sw('kpj',this)">8. Pintu &amp; Jendela</button>
      <button class="tab-btn" onclick="sw('sanitasi',this)">9. Sanitasi</button>
      <button class="tab-btn" onclick="sw('mep',this)">10. Listrik</button>
      <button class="tab-btn" onclick="sw('finishing',this)">11. Finishing</button>
      <button class="tab-btn" onclick="sw('rekap',this)">&#9654; Rekap Total</button>
    </div>

    <!-- TAB 1: TANAH -->
    <div id="p_tanah" class="tab-panel active">
      <div class="sec-card">
        <div class="sec-head"><span class="sn">01</span><span class="st">Pekerjaan Tanah</span><span class="sb" id="b1">Rp 0</span></div>
        <div class="two-col">
          <div class="col-pane">
            <div class="sub-label">Dimensi galian</div>
            <div class="field-row"><label>Panjang total galian</label><input type="number" id="g_p" value="48" oninput="calcAll()"><span class="unit">m</span></div>
            <div class="field-row"><label>Lebar galian</label><input type="number" id="g_l" value="0.60" oninput="calcAll()"><span class="unit">m</span></div>
            <div class="field-row"><label>Kedalaman galian</label><input type="number" id="g_h" value="0.80" oninput="calcAll()"><span class="unit">m</span></div>
            <div class="field-row"><label>Urugan kembali (%)</label><input type="number" id="g_uf" value="30" oninput="calcAll()"><span class="unit">%</span></div>
            <div class="field-row"><label>Luas urugan pasir</label><input type="number" id="g_ups" value="36" oninput="calcAll()"><span class="unit">m²</span></div>
            <div class="field-row"><label>Tebal urugan pasir</label><input type="number" id="g_upt" value="0.10" oninput="calcAll()"><span class="unit">m</span></div>
          </div>
          <div class="col-pane">
            <div class="sub-label">Harga satuan</div>
            <div class="field-row"><label>Galian tanah biasa</label><input type="number" id="hs_gal" value="55000" oninput="calcAll()"><span class="unit">/m³</span></div>
            <div class="field-row"><label>Urugan kembali &amp; padat</label><input type="number" id="hs_uru" value="60000" oninput="calcAll()"><span class="unit">/m³</span></div>
            <div class="field-row"><label>Urugan pasir bawah lantai</label><input type="number" id="hs_ups" value="85000" oninput="calcAll()"><span class="unit">/m³</span></div>
            <div class="field-row"><label>Sewa stamper</label><input type="number" id="hs_sta" value="150000" oninput="calcAll()"><span class="unit">/hr</span></div>
            <div class="field-row"><label>Durasi sewa stamper</label><input type="number" id="dur_sta" value="2" oninput="calcAll()"><span class="unit">hr</span></div>
          </div>
        </div>
        <div class="tbl-wrap"><table class="rtbl" id="tbl1"></table></div>
      </div>
    </div>

    <!-- TAB 2: PONDASI -->
    <div id="p_pondasi" class="tab-panel">
      <div class="sec-card">
        <div class="sec-head"><span class="sn">02</span><span class="st">Pekerjaan Pondasi Batu Kali</span><span class="sb" id="b2">Rp 0</span></div>
        <div class="two-col">
          <div class="col-pane">
            <div class="sub-label">Dimensi pondasi</div>
            <div class="field-row"><label>Panjang total pondasi</label><input type="number" id="pd_p" value="48" oninput="calcAll()"><span class="unit">m</span></div>
            <div class="field-row"><label>Tinggi pondasi</label><input type="number" id="pd_h" value="0.60" oninput="calcAll()"><span class="unit">m</span></div>
            <div class="field-row"><label>Lebar atas</label><input type="number" id="pd_la" value="0.30" oninput="calcAll()"><span class="unit">m</span></div>
            <div class="field-row"><label>Lebar bawah</label><input type="number" id="pd_lb" value="0.60" oninput="calcAll()"><span class="unit">m</span></div>
            <div class="field-row"><label>Tebal aanstamping</label><input type="number" id="pd_at" value="0.15" oninput="calcAll()"><span class="unit">m</span></div>
          </div>
          <div class="col-pane">
            <div class="sub-label">Harga satuan</div>
            <div class="field-row"><label>Batu kali</label><input type="number" id="hs_batu" value="350000" oninput="calcAll()"><span class="unit">/m³</span></div>
            <div class="field-row"><label>Semen PC</label><input type="number" id="hs_spc" value="65000" oninput="calcAll()"><span class="unit">/sak</span></div>
            <div class="field-row"><label>Pasir pasang</label><input type="number" id="hs_psp" value="380000" oninput="calcAll()"><span class="unit">/m³</span></div>
            <div class="field-row"><label>Pekerja</label><input type="number" id="hs_p2" value="80000" oninput="calcAll()"><span class="unit">/OH</span></div>
            <div class="field-row"><label>Tukang batu</label><input type="number" id="hs_t2" value="135000" oninput="calcAll()"><span class="unit">/OH</span></div>
            <div class="field-row"><label>Mandor</label><input type="number" id="hs_m2" value="170000" oninput="calcAll()"><span class="unit">/OH</span></div>
          </div>
        </div>
        <div class="tbl-wrap"><table class="rtbl" id="tbl2"></table></div>
      </div>
    </div>

    <!-- TAB 3: STRUKTUR -->
    <div id="p_struktur" class="tab-panel">
      <div class="sec-card">
        <div class="sec-head"><span class="sn">03</span><span class="st">Struktur Beton (Sloof + Kolom + Ring Balok)</span><span class="sb" id="b3">Rp 0</span></div>
        <div class="two-col">
          <div class="col-pane">
            <div class="sub-label">Sloof</div>
            <div class="field-row"><label>Panjang total</label><input type="number" id="sl_p" value="40" oninput="calcAll()"><span class="unit">m</span></div>
            <div class="field-row"><label>Lebar (b)</label><input type="number" id="sl_b" value="0.15" oninput="calcAll()"><span class="unit">m</span></div>
            <div class="field-row"><label>Tinggi (h)</label><input type="number" id="sl_h" value="0.20" oninput="calcAll()"><span class="unit">m</span></div>
            <hr class="divline">
            <div class="sub-label">Kolom</div>
            <div class="field-row"><label>Jumlah kolom</label><input type="number" id="kl_j" value="12" oninput="calcAll()"><span class="unit">bh</span></div>
            <div class="field-row"><label>b × h kolom</label><input type="number" id="kl_b" value="0.15" oninput="calcAll()"><span class="unit">m</span></div>
            <div class="field-row"><label>Tinggi kolom</label><input type="number" id="kl_t" value="3.00" oninput="calcAll()"><span class="unit">m</span></div>
            <hr class="divline">
            <div class="sub-label">Ring Balok</div>
            <div class="field-row"><label>Panjang total</label><input type="number" id="rb_p" value="40" oninput="calcAll()"><span class="unit">m</span></div>
            <div class="field-row"><label>Lebar (b)</label><input type="number" id="rb_b" value="0.15" oninput="calcAll()"><span class="unit">m</span></div>
            <div class="field-row"><label>Tinggi (h)</label><input type="number" id="rb_h" value="0.20" oninput="calcAll()"><span class="unit">m</span></div>
          </div>
          <div class="col-pane">
            <div class="sub-label">Tulangan (semua elemen)</div>
            <div class="field-row"><label>Diameter tul. utama</label><input type="number" id="st_d1" value="12" oninput="calcAll()"><span class="unit">mm</span></div>
            <div class="field-row"><label>Jumlah tulangan</label><input type="number" id="st_nt" value="4" oninput="calcAll()"><span class="unit">bh</span></div>
            <div class="field-row"><label>Diameter sengkang</label><input type="number" id="st_ds" value="8" oninput="calcAll()"><span class="unit">mm</span></div>
            <div class="field-row"><label>Jarak sengkang</label><input type="number" id="st_js" value="15" oninput="calcAll()"><span class="unit">cm</span></div>
            <hr class="divline">
            <div class="sub-label">Harga satuan bahan</div>
            <div class="field-row"><label>Besi tulangan</label><input type="number" id="hs_besi" value="14500" oninput="calcAll()"><span class="unit">/kg</span></div>
            <div class="field-row"><label>Semen PC</label><input type="number" id="hs_spc3" value="65000" oninput="calcAll()"><span class="unit">/sak</span></div>
            <div class="field-row"><label>Pasir beton</label><input type="number" id="hs_pb3" value="420000" oninput="calcAll()"><span class="unit">/m³</span></div>
            <div class="field-row"><label>Batu split</label><input type="number" id="hs_bs3" value="400000" oninput="calcAll()"><span class="unit">/m³</span></div>
            <div class="field-row"><label>Kayu bekisting</label><input type="number" id="hs_kb3" value="8000000" oninput="calcAll()"><span class="unit">/m³</span></div>
            <hr class="divline">
            <div class="sub-label">Tenaga kerja</div>
            <div class="field-row"><label>Pekerja</label><input type="number" id="hs_p3" value="80000" oninput="calcAll()"><span class="unit">/OH</span></div>
            <div class="field-row"><label>Tukang</label><input type="number" id="hs_t3" value="135000" oninput="calcAll()"><span class="unit">/OH</span></div>
            <div class="field-row"><label>Mandor</label><input type="number" id="hs_m3" value="170000" oninput="calcAll()"><span class="unit">/OH</span></div>
          </div>
        </div>
        <div class="tbl-wrap"><table class="rtbl" id="tbl3"></table></div>
      </div>
    </div>

    <!-- TAB 4: DINDING -->
    <div id="p_dinding" class="tab-panel">
      <div class="sec-card">
